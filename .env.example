# Copy this file to ".env" and fill in what you want, then launch the server.
# Everything here is optional — Hestia runs with none of it (rule-based + mock inbox).

# --- Run the real concierge agent (instead of the keyless rule-based reader) ---
HESTIA_USE_LLM=1
GOOGLE_API_KEY=your-gemini-api-key
GOOGLE_GENAI_USE_VERTEXAI=FALSE
SENTINEL_MODEL=gemini-3.5-flash

# --- Read a REAL inbox with "Scan inbox" (use a dedicated throwaway Gmail) ---
# 1) Gmail -> Settings -> enable IMAP.
# 2) Google Account -> Security -> 2-Step Verification -> App passwords ->
#    create one for "Mail" and paste the 16-char code below.
IMAP_HOST=imap.gmail.com
IMAP_USER=youraddress@gmail.com
IMAP_PASS=your-16-char-app-password

# --- Production: hide the demo sample-document buttons ---
# HESTIA_DEMO=0
